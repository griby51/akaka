CXX = x86_64-w64-mingw32-g++
TARGET = main.exe
SRCS = $(wildcard src/*.cpp)
OBJS = $(SRCS:src/%.cpp=build/%.o)

CXXFLAGS = -I/usr/x86_64-w64-mingw32/include/SDL2 -Iinclude -Dmain=SDL_main -g

LDFLAGS = -lmingw32 -lSDL2main -lSDL2 -lSDL2_ttf -lSDL2_image -lSDL2_mixer \
          -lsetupapi -lcfgmgr32 -lole32 -luuid -lversion \
          -static-libgcc -static-libstdc++ -Wl,--subsystem,windows

all: build $(TARGET)
build:
	mkdir -p build

$(TARGET): $(OBJS)
	$(CXX) $(OBJS) -o $(TARGET) $(LDFLAGS)

build/%.o: src/%.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	rm -rf build $(TARGET)

.PHONY: all clean build
